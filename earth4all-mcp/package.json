{
  "name": "earth4all-mcp",
  "version": "0.1.0",
  "description": "MCP server for the Earth4All integrated assessment model",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "start:modelling": "npx tsx src/servers/modelling-server.ts",
    "start:explorer": "npx tsx src/servers/explorer-server.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
